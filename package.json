{
  "name": "side-chat",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "test-harness/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "build": "tsc -b --pretty false",
    "lint:oxlint": "oxlint --deny-warnings .",
    "lint:custom": "node scripts/run-custom-lints.mjs",
    "lint": "npm run lint:oxlint && npm run lint:custom",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.check.json",
    "test": "vitest run",
    "test:db:integration": "vitest run packages/db/src/repositories/postgres-drizzle.integration.test.ts",
    "test:db:container": "node scripts/run-db-container-tests.mjs",
    "test:db:local": "npm run test:db:container",
    "test:e2e": "node node_modules/playwright/cli.js test",
    "test:e2e:persistent": "node scripts/run-persistent-e2e.mjs",
    "smoke:provider:openai": "tsx --conditions=development scripts/smoke-openai-provider.mjs",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run format:check && npm run lint:oxlint && npm run typecheck && npm test && npm run build && npm run lint:custom",
    "verify:container": "node scripts/run-verify-container.mjs"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.70",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "happy-dom": "20.9.0",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.60.0",
    "tailwindcss": "4.3.0",
    "testcontainers": "12.0.0",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": "24.16.0",
    "npm": "11.15.0"
  },
  "packageManager": "npm@11.15.0"
}
