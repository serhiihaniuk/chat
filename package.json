{
  "name": "side-chat-assistant",
  "private": true,
  "packageManager": "npm@11.12.1",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/side-chat-api",
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test --config apps/embedded-host-app/playwright.config.ts",
    "lint": "node scripts/governance-check.mjs",
    "quality:inventory": "node scripts/code-quality-inventory.mjs",
    "verify": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.63",
    "@ai-sdk/react": "3.0.184",
    "ai": "6.0.182",
    "ai-elements": "1.9.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "effect": "4.0.0-beta.66",
    "hono": "4.12.18",
    "lucide-react": "1.16.0",
    "pg": "8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.4.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.8.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "shadcn": "4.7.0",
    "tsup": "8.5.1",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vitest": "4.1.6"
  }
}
