{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../../packages/shared"
    },
    {
      "path": "../../packages/host-bridge"
    },
    {
      "path": "../../packages/side-chat-widget"
    }
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
