# Local Docker demo defaults.
#
# Copy this file to `.env` if you want persistent local overrides.
# `.env` is gitignored; do not commit real API keys.

USE_FAKE_MODEL=true
SIDE_CHAT_FAKE_CHUNK_DELAY_MS=0

# To use the real OpenAI adapter locally, set:
# USE_FAKE_MODEL=false
# OPENAI_API_KEY=sk-...

# Optional local Docker image labels.
IMAGE_PREFIX=sidechat-local
IMAGE_TAG=local

# Optional local host ports.
LOCAL_DEMO_PORT=8080
SIDE_CHAT_API_PORT=3000
DASHBOARD_DATA_API_PORT=3100
POSTGRES_PORT=5432

# Optional local database superuser password for the Postgres container.
POSTGRES_PASSWORD=postgres
