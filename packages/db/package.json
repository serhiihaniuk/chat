{
  "name": "@side-chat/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#drizzle/*": {
      "types": "./src/drizzle/*.ts",
      "development": "./src/drizzle/*.ts",
      "default": "./dist/drizzle/*.js"
    },
    "#schema-contract": {
      "types": "./src/schema-contract/index.ts",
      "development": "./src/schema-contract/index.ts",
      "default": "./dist/schema-contract/index.js"
    },
    "#schema-contract/*": {
      "types": "./src/schema-contract/*.ts",
      "development": "./src/schema-contract/*.ts",
      "default": "./dist/schema-contract/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema-contract": {
      "types": "./dist/schema-contract/index.d.ts",
      "default": "./dist/schema-contract/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@side-chat/chat-protocol": "0.0.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10"
  }
}
