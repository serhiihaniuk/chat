{
  "name": "@side-chat/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#drizzle/*": {
      "types": "./src/drizzle/*.ts",
      "development": "./src/drizzle/*.ts",
      "default": "./dist/drizzle/*.js"
    },
    "#schema-contract": {
      "types": "./src/schema-contract/index.ts",
      "development": "./src/schema-contract/index.ts",
      "default": "./dist/schema-contract/index.js"
    },
    "#schema-contract/*": {
      "types": "./src/schema-contract/*.ts",
      "development": "./src/schema-contract/*.ts",
      "default": "./dist/schema-contract/*.js"
    },
    "#repositories/*": {
      "types": "./src/repositories/*.ts",
      "development": "./src/repositories/*.ts",
      "default": "./dist/repositories/*.js"
    },
    "#testing/*": {
      "types": "./src/testing/*.ts",
      "development": "./src/testing/*.ts",
      "default": "./dist/testing/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema-contract": {
      "types": "./src/schema-contract/index.ts",
      "development": "./src/schema-contract/index.ts",
      "default": "./dist/schema-contract/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@side-chat/shared": "0.0.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10"
  }
}
