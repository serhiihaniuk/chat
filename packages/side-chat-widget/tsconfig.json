{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../host-bridge"
    },
    {
      "path": "../shared"
    },
    {
      "path": "../stream-profile"
    }
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/**/widget-test-env.tsx"]
}
