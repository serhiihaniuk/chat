{
  "name": "@side-chat/side-chat-widget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#entities/*": {
      "types": "./src/entities/*/index.ts",
      "development": "./src/entities/*/index.ts",
      "default": "./dist/entities/*/index.js"
    },
    "#features/*": {
      "types": "./src/features/*/index.ts",
      "development": "./src/features/*/index.ts",
      "default": "./dist/features/*/index.js"
    },
    "#shared/lib/*": {
      "types": "./src/shared/lib/*.ts",
      "development": "./src/shared/lib/*.ts",
      "default": "./dist/shared/lib/*.js"
    },
    "#shared/ai/*": {
      "types": "./src/shared/ai/*.tsx",
      "development": "./src/shared/ai/*.tsx",
      "default": "./dist/shared/ai/*.js"
    },
    "#shared/ui/*": {
      "types": "./src/shared/ui/*.tsx",
      "development": "./src/shared/ui/*.tsx",
      "default": "./dist/shared/ui/*.js"
    },
    "#testing/*": {
      "types": "./src/testing/*.ts",
      "development": "./src/testing/*.ts",
      "default": "./dist/testing/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ui/activity/tool-detail": {
      "types": "./src/shared/ui/activity/tool-detail.tsx",
      "development": "./src/shared/ui/activity/tool-detail.tsx",
      "default": "./dist/shared/ui/activity/tool-detail.js"
    },
    "./ui/agent-mark": {
      "types": "./src/shared/ui/agent-mark.tsx",
      "development": "./src/shared/ui/agent-mark.tsx",
      "default": "./dist/shared/ui/agent-mark.js"
    },
    "./ui/button": {
      "types": "./src/shared/ui/button.tsx",
      "development": "./src/shared/ui/button.tsx",
      "default": "./dist/shared/ui/button.js"
    },
    "./ui/composer": {
      "types": "./src/shared/ui/composer.tsx",
      "development": "./src/shared/ui/composer.tsx",
      "default": "./dist/shared/ui/composer.js"
    },
    "./ui/conversation-item": {
      "types": "./src/shared/ui/conversation-item.tsx",
      "development": "./src/shared/ui/conversation-item.tsx",
      "default": "./dist/shared/ui/conversation-item.js"
    },
    "./ui/error-notice": {
      "types": "./src/shared/ui/error-notice.tsx",
      "development": "./src/shared/ui/error-notice.tsx",
      "default": "./dist/shared/ui/error-notice.js"
    },
    "./ui/message": {
      "types": "./src/shared/ui/message.tsx",
      "development": "./src/shared/ui/message.tsx",
      "default": "./dist/shared/ui/message.js"
    },
    "./ui/message-actions": {
      "types": "./src/shared/ui/message-actions.tsx",
      "development": "./src/shared/ui/message-actions.tsx",
      "default": "./dist/shared/ui/message-actions.js"
    },
    "./ui/model-selector": {
      "types": "./src/shared/ui/model-selector.tsx",
      "development": "./src/shared/ui/model-selector.tsx",
      "default": "./dist/shared/ui/model-selector.js"
    },
    "./ui/reasoning": {
      "types": "./src/shared/ui/reasoning.tsx",
      "development": "./src/shared/ui/reasoning.tsx",
      "default": "./dist/shared/ui/reasoning.js"
    },
    "./ui/scroll-area": {
      "types": "./src/shared/ui/scroll-area.tsx",
      "development": "./src/shared/ui/scroll-area.tsx",
      "default": "./dist/shared/ui/scroll-area.js"
    },
    "./ui/settings": {
      "types": "./src/shared/ui/settings.tsx",
      "development": "./src/shared/ui/settings.tsx",
      "default": "./dist/shared/ui/settings.js"
    },
    "./ui/tools-menu": {
      "types": "./src/shared/ui/tools-menu.tsx",
      "development": "./src/shared/ui/tools-menu.tsx",
      "default": "./dist/shared/ui/tools-menu.js"
    },
    "./ui/widget-root": {
      "types": "./src/shared/ui/widget-root.tsx",
      "development": "./src/shared/ui/widget-root.tsx",
      "default": "./dist/shared/ui/widget-root.js"
    },
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "clean": "tsc -b --clean",
    "build": "tsc -b --clean && tsc -b --pretty false",
    "typecheck": "cd ../.. && tsc --noEmit --pretty false -p tsconfig.check.json",
    "test": "cd ../.. && vitest run packages/side-chat-widget/src"
  },
  "dependencies": {
    "@ai-sdk/workflow": "1.0.32",
    "@base-ui/react": "1.5.0",
    "@side-chat/host-bridge": "0.0.0",
    "@side-chat/shared": "0.0.0",
    "@side-chat/stream-profile": "0.0.0",
    "@tanstack/react-query": "5.101.0",
    "ai": "7.0.32",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "use-stick-to-bottom": "1.1.4"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
