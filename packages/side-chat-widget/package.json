{
  "name": "@side-chat/side-chat-widget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#entities/*": {
      "types": "./src/entities/*/index.ts",
      "development": "./src/entities/*/index.ts",
      "default": "./dist/entities/*/index.js"
    },
    "#features/*": {
      "types": "./src/features/*/index.ts",
      "development": "./src/features/*/index.ts",
      "default": "./dist/features/*/index.js"
    },
    "#shared/lib/*": {
      "types": "./src/shared/lib/*.ts",
      "development": "./src/shared/lib/*.ts",
      "default": "./dist/shared/lib/*.js"
    },
    "#shared/ai/*": {
      "types": "./src/shared/ai/*.tsx",
      "development": "./src/shared/ai/*.tsx",
      "default": "./dist/shared/ai/*.js"
    },
    "#shared/ui/*": {
      "types": "./src/shared/ui/*.tsx",
      "development": "./src/shared/ui/*.tsx",
      "default": "./dist/shared/ui/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./src/entities/chat/testing.ts",
      "development": "./src/entities/chat/testing.ts",
      "default": "./dist/entities/chat/testing.js"
    },
    "./ui/*": {
      "types": "./src/shared/ui/*.tsx",
      "development": "./src/shared/ui/*.tsx",
      "default": "./dist/shared/ui/*.js"
    },
    "./ai/*": {
      "types": "./src/shared/ai/*.tsx",
      "development": "./src/shared/ai/*.tsx",
      "default": "./dist/shared/ai/*.js"
    },
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "clean": "tsc -b --clean",
    "build": "tsc -b --clean && tsc -b --pretty false",
    "typecheck": "cd ../.. && tsc --noEmit --pretty false -p tsconfig.check.json",
    "test": "cd ../.. && vitest run packages/side-chat-widget/src --passWithNoTests"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@side-chat/chat-protocol": "0.0.0",
    "@side-chat/host-bridge": "0.0.0",
    "@side-chat/shared": "0.0.0",
    "@tanstack/react-query": "5.101.0",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "use-stick-to-bottom": "1.1.4"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
