{
  "name": "@side-chat/side-chat-widget",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -b && tsup src/index.ts --format esm --dts"
  },
  "peerDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "dependencies": {
    "@side-chat/shared-protocol": "0.1.0",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.4.0",
    "use-stick-to-bottom": "1.1.4"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
