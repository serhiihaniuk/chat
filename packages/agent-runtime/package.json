{
  "name": "@side-chat/agent-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#fake/*": {
      "types": "./src/fake/*.ts",
      "development": "./src/fake/*.ts",
      "default": "./dist/fake/*.js"
    },
    "#registry/*": {
      "types": "./src/registry/*.ts",
      "development": "./src/registry/*.ts",
      "default": "./dist/registry/*.js"
    },
    "#runtime/*": {
      "types": "./src/runtime/*.ts",
      "development": "./src/runtime/*.ts",
      "default": "./dist/runtime/*.js"
    },
    "#tools/*": {
      "types": "./src/tools/*.ts",
      "development": "./src/tools/*.ts",
      "default": "./dist/tools/*.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.json",
    "test": "cd ../.. && vitest run packages/agent-runtime/src/fake/fake-provider.test.ts packages/agent-runtime/src/registry/provider-registry.test.ts packages/agent-runtime/src/tools/tool-registry.test.ts packages/agent-runtime/src/runtime/agent-runtime.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.65",
    "@ai-sdk/provider": "3.0.10",
    "@side-chat/partner-ai-core": "0.0.0",
    "@side-chat/chat-protocol": "0.0.0",
    "ai": "6.0.191",
    "effect": "4.0.0-beta.70"
  }
}
