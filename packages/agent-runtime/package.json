{
  "name": "@side-chat/agent-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#providers/*": {
      "types": "./src/providers/*.ts",
      "development": "./src/providers/*.ts",
      "default": "./dist/providers/*.js"
    },
    "#providers/fake/*": {
      "types": "./src/providers/fake/*.ts",
      "development": "./src/providers/fake/*.ts",
      "default": "./dist/providers/fake/*.js"
    },
    "#providers/openai/*": {
      "types": "./src/providers/openai/*.ts",
      "development": "./src/providers/openai/*.ts",
      "default": "./dist/providers/openai/*.js"
    },
    "#runtime/*": {
      "types": "./src/runtime/*.ts",
      "development": "./src/runtime/*.ts",
      "default": "./dist/runtime/*.js"
    },
    "#testing/*": {
      "types": "./src/testing/*.ts",
      "development": "./src/testing/*.ts",
      "default": "./dist/testing/*.js"
    },
    "#tools/*": {
      "types": "./src/tools/*.ts",
      "development": "./src/tools/*.ts",
      "default": "./dist/tools/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.json",
    "test": "cd ../.. && vitest run packages/agent-runtime/src/providers/fake/fake-model-provider.test.ts packages/agent-runtime/src/providers/openai/openai-model-provider.test.ts packages/agent-runtime/src/tools/tool-registry.test.ts packages/agent-runtime/src/runtime/agent-runtime.test.ts packages/agent-runtime/src/runtime/ai-sdk/tools/ai-sdk-tool-adapter.test.ts packages/agent-runtime/src/provider.type.test.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.65",
    "@ai-sdk/provider": "3.0.10",
    "@side-chat/shared": "0.0.0",
    "ai": "6.0.191",
    "effect": "4.0.0-beta.70",
    "zod": "4.4.3"
  }
}
