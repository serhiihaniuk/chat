      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "cd ../.. && vitest run packages/chat-protocol/src --passWithNoTests"
  },
  "dependencies": {
    "@side-chat/shared": "0.0.0"
  }
}
