{
  "name": "@side-chat/chat-protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#sidechat-v1/*": {
      "types": "./src/sidechat-v1/*.ts",
      "development": "./src/sidechat-v1/*.ts",
      "default": "./dist/sidechat-v1/*.js"
    }
  },
  "exports": {
