{
  "name": "@side-chat/chat-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#http/*": {
      "types": "./src/http/*.ts",
      "development": "./src/http/*.ts",
      "default": "./dist/http/*.js"
    },
    "#resources/*": {
      "types": "./src/resources/*.ts",
      "development": "./src/resources/*.ts",
      "default": "./dist/resources/*.js"
    },
    "#transport/*": {
      "types": "./src/transport/*.ts",
      "development": "./src/transport/*.ts",
      "default": "./dist/transport/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "cd ../.. && tsc --noEmit --pretty false -p tsconfig.check.json",
    "test": "cd ../.. && vitest run packages/chat-client/src/transport/sse-reader.test.ts packages/chat-client/src/transport/client.test.ts packages/chat-client/src/transport/client.type.test.ts"
  },
  "dependencies": {
    "@side-chat/chat-protocol": "0.0.0",
    "@side-chat/shared": "0.0.0"
  }
}
