{
  "name": "@side-chat/partner-ai-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#application/*": {
      "types": "./src/application/*.ts",
      "development": "./src/application/*.ts",
      "default": "./dist/application/*.js"
    },
    "#domain/*": {
      "types": "./src/domain/*.ts",
      "development": "./src/domain/*.ts",
      "default": "./dist/domain/*.js"
    },
    "#errors": {
      "types": "./src/errors/index.ts",
      "development": "./src/errors/index.ts",
      "default": "./dist/errors/index.js"
    },
    "#policies/*": {
      "types": "./src/policies/*.ts",
      "development": "./src/policies/*.ts",
      "default": "./dist/policies/*.js"
    },
    "#ports": {
      "types": "./src/ports/index.ts",
      "development": "./src/ports/index.ts",
      "default": "./dist/ports/index.js"
    },
    "#services/*": {
      "types": "./src/services/*.ts",
      "development": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#testing/*": {
      "types": "./src/testing/*.ts",
      "development": "./src/testing/*.ts",
      "default": "./dist/testing/*.js"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@side-chat/ai-runtime-contract": "0.0.0",
    "@side-chat/chat-protocol": "0.0.0",
    "@side-chat/shared": "0.0.0",
    "effect": "4.0.0-beta.70"
  }
}
