{$DEMO_DOMAIN} {
	encode zstd gzip

	route {
		handle /chat/* {
			reverse_proxy side-chat-api:3000
		}

		handle /models {
			reverse_proxy side-chat-api:3000
		}

		handle /health {
			reverse_proxy side-chat-api:3000
		}

		handle /reports/* {
			reverse_proxy side-chat-api:3000
		}

		handle /advisory-dashboard/* {
			reverse_proxy dashboard-data-api:3100
		}

		handle /dashboard-health {
			reverse_proxy dashboard-data-api:3100
		}

		handle {
			reverse_proxy embedded-host-app:8080
		}
	}
}
