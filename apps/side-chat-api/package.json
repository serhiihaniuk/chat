{
  "name": "@side-chat/side-chat-api",
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#adapters/*.js": {
      "types": "./src/adapters/*.ts",
      "development": "./src/adapters/*.ts",
      "default": "./dist/adapters/*.js"
    },
    "#application/*.js": {
      "types": "./src/application/*.ts",
      "development": "./src/application/*.ts",
      "default": "./dist/application/*.js"
    },
    "#inbound/*.js": {
      "types": "./src/inbound/*.ts",
      "development": "./src/inbound/*.ts",
      "default": "./dist/inbound/*.js"
    },
    "#ports/*.js": {
      "types": "./src/ports/*.ts",
      "development": "./src/ports/*.ts",
      "default": "./dist/ports/*.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "node --conditions=development --import tsx src/server.ts",
    "build": "tsc -b"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.63",
    "@hono/node-server": "1.19.14",
    "@side-chat/db": "0.1.0",
    "@side-chat/shared-protocol": "0.1.0",
    "ai": "6.0.182",
    "effect": "4.0.0-beta.66",
    "hono": "4.12.18",
    "playwright": "1.60.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "tsx": "4.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
