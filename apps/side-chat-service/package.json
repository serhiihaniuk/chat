{
  "name": "@side-chat/side-chat-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./src/index.ts",
  "imports": {
    "#application/*": {
      "types": "./src/application/*.ts",
      "development": "./src/application/*.ts",
      "default": "./src/application/*.ts"
    },
    "#adapters/*": {
      "types": "./src/adapters/*.ts",
      "development": "./src/adapters/*.ts",
      "default": "./src/adapters/*.ts"
    },
    "#composition/*": {
      "types": "./src/composition/*.ts",
      "development": "./src/composition/*.ts",
      "default": "./src/composition/*.ts"
    },
    "#config/*": {
      "types": "./src/config/*.ts",
      "development": "./src/config/*.ts",
      "default": "./src/config/*.ts"
    },
    "#testing/*": {
      "types": "./src/testing/*.ts",
      "development": "./src/testing/*.ts",
      "default": "./src/testing/*.ts"
    },
    "#workflows/*": {
      "types": "./src/workflows/*.ts",
      "development": "./src/workflows/*.ts",
      "default": "./src/workflows/*.ts"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "nitro build",
    "build:testing": "node ../../scripts/build-side-chat-service-testing.mjs",
    "dev": "nitro dev",
    "start": "node .output/server/index.mjs",
    "test": "cd ../.. && vitest run apps/side-chat-service/src/composition/route/service-compatibility.integration.test.ts",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@ai-sdk/provider": "4.0.3",
    "@ai-sdk/workflow": "1.0.22",
    "@workflow/serde": "5.0.0-beta.2",
    "@workflow/world-postgres": "5.0.0-beta.24",
    "ai": "7.0.22",
    "hono": "4.12.27",
    "nitro": "3.0.260610-beta",
    "rollup": "4.62.2",
    "workflow": "5.0.0-beta.30"
  }
}
